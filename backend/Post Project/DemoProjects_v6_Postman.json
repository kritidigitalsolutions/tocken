{
  "info": {
    "_postman_id": "clean-lead-projects-v6",
    "name": "Projects API — v6 (Multipart + Simplified Routes)",
    "description": "Complete project API collection.\n\nRoute summary:\n  POST   /api/projects                      → Create project (multipart: data JSON + files)\n  PUT    /api/projects/:id                  → Update project (multipart: data JSON + files)\n  DELETE /api/projects/:id                  → Delete project (PENDING only)\n\n  GET    /api/projects/developer/me         → Get my developer profile\n  PUT    /api/projects/developer/me         → Update developer text data (JSON)\n  PATCH  /api/projects/developer/me/uploads → Upload developer files\n                                               fields: logo | panDocument | reraCertificate | gstCertificate\n\n  PATCH  /api/projects/:id/uploads          → Upload project files\n                                               fields: mainImage | gallery | brochure | floorPlan (+configType text)\n  DELETE /api/projects/:id/gallery/:index   → Remove gallery image by index\n\nMultipart pattern for create/update:\n  Key: data    Type: Text    Value: {full JSON string}\n  Key: mainImage / gallery / brochure / floorPlan   Type: File\n\nSet BASE_URL variable before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",    "value": "http://localhost:5000" },
    { "key": "USER_TOKEN",  "value": "" },
    { "key": "ADMIN_TOKEN", "value": "" },
    { "key": "PROJECT_ID",  "value": "" }
  ],
  "item": [
    {
      "name": "0 — AUTH",
      "item": [
        {
          "name": "0-A  User: Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/send-otp", "host": ["{{BASE_URL}}"], "path": ["api","auth","send-otp"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"mobileNo\": \"8273243959\"\n}"
            }
          }
        },
        {
          "name": "0-B  User: Verify OTP (saves USER_TOKEN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/auth/verify-otp", "host": ["{{BASE_URL}}"], "path": ["api","auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"mobileNo\": \"8273243959\",\n  \"otp\": \"<ENTER OTP HERE>\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "const t = j.data?.token || j.token;",
            "if (t) { pm.collectionVariables.set('USER_TOKEN', t); console.log('USER_TOKEN saved'); }"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "0-C  Admin: Login (saves ADMIN_TOKEN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/api/admin/auth/login", "host": ["{{BASE_URL}}"], "path": ["api","admin","auth","login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"kumar041232@gmail.com\",\n  \"password\": \"Agra@123\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "const t = j.data?.token || j.token;",
            "if (t) { pm.collectionVariables.set('ADMIN_TOKEN', t); console.log('ADMIN_TOKEN saved'); }"
          ], "type": "text/javascript" } }]
        }
      ]
    },
    {
      "name": "1 — DEVELOPER PROFILE",
      "item": [
        {
          "name": "1-A  Get My Developer Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/developer/me", "host": ["{{BASE_URL}}"], "path": ["api","projects","developer","me"] }
          }
        },
        {
          "name": "1-B  Update Developer Text Data (JSON)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/api/projects/developer/me", "host": ["{{BASE_URL}}"], "path": ["api","projects","developer","me"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"nameOfBusiness\": \"GreenBuilders Pvt Ltd\",\n  \"nameOfAuthorisedPerson\": \"Rajesh Kumar\",\n  \"designation\": \"Managing Director\",\n  \"businessPAN\": \"AABCG1234K\",\n  \"email\": \"rajesh@greenbuilders.in\",\n  \"mobileNo\": \"9876543210\",\n  \"reraNo\": \"P52100012345\",\n  \"gstNo\": \"27AABCG1234K1Z5\",\n  \"websiteLink\": \"https://greenbuilders.in\",\n  \"developerProfileDescription\": \"GreenBuilders Pvt Ltd — 15+ years delivering quality real estate projects.\"\n}"
            }
          }
        },
        {
          "name": "1-C  Upload Developer Files (PATCH /developer/me/uploads)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/developer/me/uploads", "host": ["{{BASE_URL}}"], "path": ["api","projects","developer","me","uploads"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "logo",            "type": "file", "src": [], "description": "Developer logo (JPG/PNG/WEBP)" },
                { "key": "panDocument",     "type": "file", "src": [], "description": "PAN card image or PDF (max 20 MB)" },
                { "key": "reraCertificate", "type": "file", "src": [], "description": "RERA certificate PDF or image" },
                { "key": "gstCertificate",  "type": "file", "src": [], "description": "GST certificate PDF or image" }
              ]
            },
            "description": "All fields optional — send only what needs to be uploaded/updated."
          }
        }
      ]
    },
    {
      "name": "2 — PROJECTS",
      "item": [
        {
          "name": "2-A  Create Project (multipart: data + mainImage)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects", "host": ["{{BASE_URL}}"], "path": ["api","projects"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "data",
                  "type": "text",
                  "value": "{\n  \"nameOfProject\": \"Green Valley Heights\",\n  \"noOfFloor\": 20,\n  \"noOfTower\": 3,\n  \"projectStatus\": \"New launch\",\n  \"description\": \"A premium residential gated community with world-class amenities.\",\n  \"launchDate\": \"2026-04-01\",\n  \"possessionDate\": \"2028-12-31\",\n  \"projectType\": [\"Residential\"],\n  \"projectLocation\": {\n    \"fullAddress\": \"Survey No. 45, Baner Road, Pune\",\n    \"city\": \"Pune\",\n    \"state\": \"Maharashtra\",\n    \"country\": \"India\",\n    \"latitude\": 18.5592,\n    \"longitude\": 73.7868\n  },\n  \"projectConfiguration\": [\n    { \"type\": \"2BHK\",        \"details\": { \"areaRangeSqft\": { \"min\": 850,  \"max\": 1050 }, \"priceRange\": { \"min\": 55,  \"max\": 70  } } },\n    { \"type\": \"2.5BHK\",     \"details\": { \"areaRangeSqft\": { \"min\": 1050, \"max\": 1250 }, \"priceRange\": { \"min\": 68,  \"max\": 85  } } },\n    { \"type\": \"3BHK\",       \"details\": { \"areaRangeSqft\": { \"min\": 1250, \"max\": 1550 }, \"priceRange\": { \"min\": 80,  \"max\": 105 } } },\n    { \"type\": \"3BHK Duplex\",\"details\": { \"areaRangeSqft\": { \"min\": 1600, \"max\": 2000 }, \"priceRange\": { \"min\": 110, \"max\": 145 } } }\n  ],\n  \"projectFeature\": [\"Earthquake Resistant\", \"Vastu Compliant\", \"RERA Approved\", \"Gated Community\", \"24x7 Security\"],\n  \"productSpecification\": [\"Vitrified Tiles\", \"Modular Kitchen\", \"Premium Sanitary Fittings\", \"Powder Coated Windows\"],\n  \"amenities\": [\"Swimming Pool\", \"Gym\", \"Clubhouse\", \"Children Play Area\", \"Jogging Track\", \"Indoor Games\", \"Landscaped Gardens\"],\n  \"connectivity\": [\"500m from Metro\", \"2km from Expressway\", \"3km from Symbiosis College\", \"10km from Airport\"],\n  \"nameOfBusiness\": \"GreenBuilders Pvt Ltd\",\n  \"nameOfAuthorisedPerson\": \"Rajesh Kumar\",\n  \"designation\": \"Managing Director\",\n  \"businessPAN\": \"AABCG1234K\",\n  \"email\": \"rajesh@greenbuilders.in\",\n  \"mobileNo\": \"9876543210\",\n  \"reraNo\": \"P52100012345\",\n  \"gstNo\": \"27AABCG1234K1Z5\",\n  \"websiteLink\": \"https://greenbuilders.in\",\n  \"developerProfileDescription\": \"GreenBuilders Pvt Ltd — 15+ years delivering quality projects.\"\n}",
                  "description": "ALL project + developer fields as a single JSON string in the 'data' key"
                },
                { "key": "mainImage", "type": "file", "src": [], "description": "Cover image (JPG/PNG/WEBP, max 10 MB)" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.data?.projectId) {",
            "  pm.collectionVariables.set('PROJECT_ID', j.data.projectId);",
            "  console.log('PROJECT_ID saved:', j.data.projectId);",
            "}"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "2-B  Update Project Text + Gallery (multipart)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "data",
                  "type": "text",
                  "value": "{\n  \"description\": \"Updated: Premium gated community with modern architecture and green spaces.\"\n}",
                  "description": "Only include fields you want to update"
                },
                { "key": "gallery", "type": "file", "src": [], "description": "Gallery image 1" },
                { "key": "gallery", "type": "file", "src": [], "description": "Gallery image 2" },
                { "key": "gallery", "type": "file", "src": [], "description": "Gallery image 3" }
              ]
            }
          }
        },
        {
          "name": "2-C  Upload Project Files — Brochure + Cover (PATCH /uploads)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}/uploads", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}","uploads"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "mainImage", "type": "file", "src": [], "description": "Replaces cover photo" },
                { "key": "brochure",  "type": "file", "src": [], "description": "eBrochure PDF or image" }
              ]
            },
            "description": "All fields optional — send any combination of file fields."
          }
        },
        {
          "name": "2-D  Floor Plan — 2BHK",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}/uploads", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}","uploads"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "configType", "value": "2BHK",        "type": "text" },
                { "key": "floorPlan",  "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "2-E  Floor Plan — 2.5BHK",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}/uploads", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}","uploads"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "configType", "value": "2.5BHK",      "type": "text" },
                { "key": "floorPlan",  "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "2-F  Floor Plan — 3BHK",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}/uploads", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}","uploads"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "configType", "value": "3BHK",        "type": "text" },
                { "key": "floorPlan",  "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "2-G  Floor Plan — 3BHK Duplex",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}/uploads", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}","uploads"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "configType", "value": "3BHK Duplex",  "type": "text" },
                { "key": "floorPlan",  "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "2-H  Remove Gallery Image by Index",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}/gallery/0",
              "host": ["{{BASE_URL}}"],
              "path": ["api","projects","{{PROJECT_ID}}","gallery","0"],
              "description": "Change '0' to the gallery index to remove"
            }
          }
        },
        {
          "name": "2-I  Delete Project (PENDING only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{USER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}"] }
          }
        }
      ]
    },
    {
      "name": "3 — ADMIN",
      "item": [
        {
          "name": "3-A  [ADMIN] Approve Project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/api/admin/projects/{{PROJECT_ID}}/status", "host": ["{{BASE_URL}}"], "path": ["api","admin","projects","{{PROJECT_ID}}","status"] },
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"status\": \"ACTIVE\"\n}" }
          }
        },
        {
          "name": "3-B  [ADMIN] Reject Project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/api/admin/projects/{{PROJECT_ID}}/status", "host": ["{{BASE_URL}}"], "path": ["api","admin","projects","{{PROJECT_ID}}","status"] },
            "body": { "mode": "raw", "options": { "raw": { "language": "json" } }, "raw": "{\n  \"status\": \"REJECTED\",\n  \"rejectionReason\": \"Incomplete documentation provided.\"\n}" }
          }
        },
        {
          "name": "3-C  [ADMIN] Toggle Featured",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{ADMIN_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/api/admin/projects/{{PROJECT_ID}}/featured", "host": ["{{BASE_URL}}"], "path": ["api","admin","projects","{{PROJECT_ID}}","featured"] }
          }
        },
        {
          "name": "3-D  [PUBLIC] Get Project by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/api/projects/{{PROJECT_ID}}", "host": ["{{BASE_URL}}"], "path": ["api","projects","{{PROJECT_ID}}"] }
          }
        }
      ]
    }
  ]
}
