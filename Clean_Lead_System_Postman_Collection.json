{
  "info": {
    "name": "🔥 Clean Lead System - Real Estate App",
    "description": "Clean, admin-controlled lead system where users request leads and admin assigns actual buyer/renter contacts",
    "_postman_id": "clean-lead-system-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{USER_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "USER_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "ADMIN_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "REQUEST_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "LEAD_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "USER_ID",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "📋 STEP 1: Authentication",
      "description": "Login to get tokens",
      "item": [
        {
          "name": "1️⃣ Login User (AGENT/BUILDER/INDIVIDUAL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{BASE_URL}}/auth/login",
            "description": "Login as user to get token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.token) {",
                  "        pm.collectionVariables.set('USER_TOKEN', response.token);",
                  "        if (response.data && response.data._id) {",
                  "            pm.collectionVariables.set('USER_ID', response.data._id);",
                  "        }",
                  "        pm.test('✅ User login successful', () => {",
                  "            pm.expect(response.success).to.be.true;",
                  "        });",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2️⃣ Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{BASE_URL}}/admin/login",
            "description": "Login as admin to get token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.token) {",
                  "        pm.collectionVariables.set('ADMIN_TOKEN', response.token);",
                  "        pm.test('✅ Admin login successful', () => {",
                  "            pm.expect(response.success).to.be.true;",
                  "        });",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔹 STEP 2: User Lead Request Flow",
      "description": "User requests leads from admin",
      "item": [
        {
          "name": "A. User → Request Direct Lead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leadType\": \"BUYERS\",\n  \"dealingCities\": [\"Agra\", \"Noida\", \"Gurgaon\"],\n  \"propertyTypes\": [\"Apartment\", \"Villa\"],\n  \"budgetRange\": {\n    \"min\": 2000000,\n    \"max\": 5000000\n  },\n  \"requestNotes\": \"Looking for premium properties with good connectivity\"\n}"
            },
            "url": "{{BASE_URL}}/leads/request",
            "description": "🔹 User submits lead request to admin"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data && response.data._id) {",
                  "        pm.collectionVariables.set('REQUEST_ID', response.data._id);",
                  "        pm.test('✅ Lead request created successfully', () => {",
                  "            pm.expect(response.success).to.be.true;",
                  "            pm.expect(response.data.status).to.eql('PENDING');",
                  "        });",
                  "    }",
                  "} else {",
                  "    pm.test('❌ Request failed: ' + pm.response.json().message, () => {",
                  "        pm.expect(pm.response.code).to.eql(201);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "User → Get My Lead Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": "{{BASE_URL}}/leads/my-requests",
            "description": "User checks their lead requests status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.test('✅ Retrieved lead requests successfully', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data).to.be.an('array');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔹 STEP 3: Admin Lead Request Management",
      "description": "Admin validates and approves/rejects requests",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{ADMIN_TOKEN}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "B. Admin → View Lead Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/admin/leads/requests?status=PENDING&page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["admin", "leads", "requests"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "🔹 Admin sees user requests with plan info"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.test('✅ Retrieved lead requests for admin', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data).to.be.an('array');",
                  "        pm.expect(response.stats).to.be.an('object');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "C. Admin → Approve Lead Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adminNotes\": \"User has valid plan and good track record. Approved for lead assignment.\"\n}"
            },
            "url": "{{BASE_URL}}/admin/leads/requests/{{REQUEST_ID}}/approve",
            "description": "🔹 Admin validates plan and approves request"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.test('✅ Lead request approved successfully', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data.status).to.eql('APPROVED');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin → Check User Quota",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": "{{BASE_URL}}/admin/leads/users/{{USER_ID}}/quota",
            "description": "Admin checks user's current quota status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.test('✅ Retrieved user quota info', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data.quota).to.be.an('object');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔹 STEP 4: Admin Lead Assignment",
      "description": "Admin assigns actual buyer/renter leads",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{ADMIN_TOKEN}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "D. Admin → Assign Actual Lead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignedTo\": \"{{USER_ID}}\",\n  \"buyerName\": \"Rahul Verma\",\n  \"phone\": \"9876543210\",\n  \"city\": \"Noida\",\n  \"requirement\": \"2BHK apartment for family, budget 30-40 lakhs\",\n  \"leadType\": \"BUYER\",\n  \"propertyId\": \"6981c711d5edbc0e3c7e8d68\"\n}"
            },
            "url": "{{BASE_URL}}/admin/leads/assign",
            "description": "🔹 Admin creates actual lead entry and decreases quota"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data && response.data._id) {",
                  "        pm.collectionVariables.set('LEAD_ID', response.data._id);",
                  "        pm.test('✅ Lead assigned successfully', () => {",
                  "            pm.expect(response.success).to.be.true;",
                  "            pm.expect(response.data.status).to.eql('NEW');",
                  "            pm.expect(response.data.source).to.eql('ADMIN');",
                  "        });",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin → Assign Another Lead (Renter)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignedTo\": \"{{USER_ID}}\",\n  \"buyerName\": \"Priya Sharma\",\n  \"phone\": \"8765432109\",\n  \"city\": \"Agra\",\n  \"requirement\": \"3BHK furnished apartment for rent, budget 25-30k monthly\",\n  \"leadType\": \"RENTER\"\n}"
            },
            "url": "{{BASE_URL}}/admin/leads/assign",
            "description": "Assign another lead (without property reference)"
          }
        },
        {
          "name": "Admin → View All Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/admin/leads?page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["admin", "leads"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Admin overview of all assigned leads"
          }
        }
      ]
    },
    {
      "name": "🔹 STEP 5: User Lead Management",
      "description": "User views and manages assigned leads",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{USER_TOKEN}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "E. User → My Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/leads/my?page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["leads", "my"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "🔹 User gets their assigned leads (buyer/renter contacts)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.test('✅ Retrieved user leads successfully', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data).to.be.an('array');",
                  "    });",
                  "    ",
                  "    // Check lead structure",
                  "    if (response.data.length > 0) {",
                  "        const lead = response.data[0];",
                  "        pm.test('✅ Lead structure is correct', () => {",
                  "            pm.expect(lead).to.have.property('buyerName');",
                  "            pm.expect(lead).to.have.property('phone');",
                  "            pm.expect(lead).to.have.property('requirement');",
                  "            pm.expect(lead).to.have.property('leadType');",
                  "            pm.expect(lead).to.have.property('status');",
                  "        });",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "F. User → Update Lead Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONTACTED\"\n}"
            },
            "url": "{{BASE_URL}}/leads/{{LEAD_ID}}",
            "description": "🔹 User updates lead status after contact"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.test('✅ Lead status updated successfully', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data.status).to.eql('CONTACTED');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "User → Update to Closed",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\"\n}"
            },
            "url": "{{BASE_URL}}/leads/{{LEAD_ID}}",
            "description": "User marks lead as closed (deal completed)"
          }
        },
        {
          "name": "User → Get Lead Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": "{{BASE_URL}}/leads/stats",
            "description": "Get user's lead statistics (total, new, contacted, closed)"
          }
        }
      ]
    },
    {
      "name": "🔹 STEP 6: Error Scenarios & Edge Cases",
      "description": "Test validation and error handling",
      "item": [
        {
          "name": "❌ Request Lead Without Required Fields",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leadType\": \"BUYERS\"\n}"
            },
            "url": "{{BASE_URL}}/leads/request",
            "description": "Should return 400 error for missing fields"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('❌ Correctly rejects incomplete request', () => {",
                  "    pm.expect(pm.response.code).to.eql(400);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.false;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Request Lead Again (Duplicate Check)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leadType\": \"RENTERS\",\n  \"dealingCities\": [\"Mumbai\"],\n  \"propertyTypes\": [\"Apartment\"]\n}"
            },
            "url": "{{BASE_URL}}/leads/request",
            "description": "Should reject if user already has pending request"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('❌ Correctly rejects duplicate request', () => {",
                  "    pm.expect(pm.response.code).to.eql(400);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.false;",
                  "    pm.expect(response.message).to.include('pending');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "❌ Admin → Reject Lead Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejectionReason\": \"User plan has expired. Please renew to receive leads.\"\n}"
            },
            "url": "{{BASE_URL}}/admin/leads/requests/{{REQUEST_ID}}/reject",
            "description": "Admin rejects a lead request"
          }
        }
      ]
    }
  ]
}